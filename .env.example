# LoveGem Framework Environment Configuration

APP_NAME="LoveGem Framework"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

# Application Key (Generated automatically)
# APP_KEY=base64:...

# Application URL
APP_URL=http://localhost:8000

# Application Debug Mode
APP_DEBUG=true

# Application Timezone
APP_TIMEZONE=UTC

# Application Locale
APP_LOCALE=en
APP_FALLBACK_LOCALE=en

# Faker Locale
APP_FAKER_LOCALE=en_US

# URL Configuration
APP_URL=http://localhost:8000

# Session Configuration
SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

# Cache Configuration
CACHE_DRIVER=file
CACHE_PREFIX=lovegem

# Queue Configuration
QUEUE_CONNECTION=sync

# Database Configuration
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=lovegem
# DB_USERNAME=root
# DB_PASSWORD=

# Mail Configuration
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@lovegem.dev"
MAIL_FROM_NAME="${APP_NAME}"

# Broadcasting Configuration
BROADCAST_DRIVER=log

# Filesystem Configuration
FILESYSTEM_DISK=local
FILESYSTEM_VISIBILITY=public

# S3 Configuration (Optional)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# AWS_BUCKET=
# AWS_URL=
# AWS_ENDPOINT=

# Redis Configuration (Optional)
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379

# Encryption Key (Generated automatically)
# ENCRYPTION_KEY=

# API Configuration
API_RATE_LIMIT=60
API_TOKEN_EXPIRY=1440

# Health Check Configuration
HEALTH_CHECK_PATH=/health

# Logging Configuration
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Sanctum Configuration
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1,127.0.0.1:8000

# Webhook Configuration
WEBHOOK_TIMEOUT=30
WEBHOOK_RETRY=3

# Profiler Configuration
PROFILER_ENABLED=true
PROFILER_SAMPLE_RATE=100

# Scheduler Configuration
SCHEDULER_ENABLED=true
