{
    "name": "lovegem/framework",
    "description": "LoveGem - Laravel se better! Privacy-first PHP framework with advanced features",
    "type": "framework",
    "license": "MIT",
    "keywords": ["framework", "laravel", "privacy", "encryption", "gdpr", "php", "eloquent", "artisan", "blade"],
    "authors": [
        {
            "name": "LoveGem Team",
            "email": "team@lovegem.dev",
            "homepage": "https://lovegem.dev"
        }
    ],
    "homepage": "https://lovegem.dev",
    "support": {
        "issues": "https://github.com/lovegem-framework/lovegem/issues",
        "source": "https://github.com/lovegem-framework/lovegem",
        "docs": "https://lovegem.dev/docs"
    },
    "require": {
        "php": ">=8.1",
        "ext-openssl": "*",
        "ext-mbstring": "*",
        "ext-json": "*",
        "ext-pdo": "*",
        "ext-sodium": "*",
        "ext-dom": "*",
        "ext-fileinfo": "*",
        "ext-bcmath": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.0",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "LoveGem\\": "src/",
            "App\\": "app/"
        },
        "files": [
            "bootstrap/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        },
        "sort-order": [
            "name",
            "type",
            "description"
        ]
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "test": "phpunit --colors=always",
        "phpstan": "phpstan analyse --memory-limit=2G",
        "cs-fix": "php-cs-fixer fix --verbose",
        "cs-check": "php-cs-fixer fix --dry-run --verbose",
        "lint": "find src -name '*.php' -exec php -l {} \\;"
    }
}
